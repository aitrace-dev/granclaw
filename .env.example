# GranClaw uses the Claude Code subscription (OAuth) — NO ANTHROPIC_API_KEY needed.
# If you set one, the orchestrator explicitly strips it before spawning the CLI.

PORT=3001
NODE_ENV=development

# Optional: set this for cloud/enterprise deployments so takeover URLs use your
# public domain instead of the LAN IP. Include scheme, no trailing slash.
# Example: https://myslug.host.granclaw.com
# GRANCLAW_PUBLIC_URL=

# PostHog telemetry (key is bundled — these override it or disable it entirely)
# POSTHOG_DISABLED=false
# POSTHOG_API_KEY=phc_xxxxxxxxxxxx      # override the bundled key
# POSTHOG_HOST=https://us.i.posthog.com

# ── Bright Data Web Unlocker ───────────────────────────────────────────────────
# Powers the fetch_website(unblocker=true) tool for bypassing bot protection.
# BRIGHTDATA_UNBLOCKER_ENABLED=true
# BRIGHTDATA_UNBLOCKER_KEY=your_key_here

