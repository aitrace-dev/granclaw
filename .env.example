# GranClaw uses the Claude Code subscription (OAuth) — NO ANTHROPIC_API_KEY needed.
# If you set one, the orchestrator explicitly strips it before spawning the CLI.

PORT=3001
NODE_ENV=development

# Optional: set this for cloud/enterprise deployments so takeover URLs use your
# public domain instead of the LAN IP. Include scheme, no trailing slash.
# Example: https://myslug.host.granclaw.com
# GRANCLAW_PUBLIC_URL=

# PostHog telemetry (key is bundled — these override it or disable it entirely)
# POSTHOG_DISABLED=false
# POSTHOG_API_KEY=phc_xxxxxxxxxxxx      # override the bundled key
# POSTHOG_HOST=https://us.i.posthog.com

# ── CAPTCHA auto-solver (CapMonster Cloud) ─────────────────────────────────────
# Enables the CapMonster browser extension in all agent browser sessions.
# Solves reCAPTCHA, hCaptcha, and Cloudflare Turnstile automatically.
# CAPMONSTER_ENABLED=true
# CAPMONSTER_API_KEY=your_key_here     # also accepted as CAPMONSTER_KEY

# ── Bright Data Web Unlocker ───────────────────────────────────────────────────
# Powers the fetch_website(unblocker=true) tool for bypassing bot protection.
# BRIGHTDATA_UNBLOCKER_ENABLED=true
# BRIGHTDATA_UNBLOCKER_KEY=your_key_here

# ── Proxy routing ──────────────────────────────────────────────────────────────
# Per-agent proxy. Set GRANCLAW_PROXY_ENABLE=true and provide a comma-separated
# list. Agents are assigned proxies round-robin by their position in agents.config.json.
# Individual agents can override via the `proxy` field in agents.config.json.
# GRANCLAW_PROXY_ENABLE=true
# GRANCLAW_PROXY_LIST=http://user:pass@host1:port,http://user:pass@host2:port
